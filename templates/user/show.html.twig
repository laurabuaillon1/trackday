{% extends 'base.html.twig' %}

{% block title %}Profil de
	{{app.user.lastName}}
	{{app.user.firstName}}
{% endblock %}

{% block body %}
	<div class="dashboard">
		<div class="bike-detail__back">
			<img src="{{asset('icons/authentification/arrow_left.svg')}}" width="16" height="16" alt="" aria-hidden="true">
			<a class="auth-card__link font-medium" href="{{ path('app_user_index') }}">Retourner sur la liste des utilisateurs</a>
		</div>
		<div class="dashboard__wrapper">
			<div class="dashboard__title">
				<img class="dashboard__icon" src="{{asset('icons/dashboard/flag_red.svg')}}" alt="" aria-hidden="true">
				<h1>Fiche de
					{{app.user.lastName}}
					{{app.user.firstName}}</h1>
			</div>
			<p class="text-m ">Retrouver toutes les informations des utilisateurs</p>
		</div>



		<table class="table">
			<tbody>
				<tr>
					<th>Nom de famille</th>
					<td>{{ user.lastName }}</td>
				</tr>
				<tr>
					<th>Prénom</th>
					<td>{{ user.firstName }}</td>
				</tr>
				<tr>
					<th>Email</th>
					<td>{{ user.email }}</td>
				</tr>
				{# <tr>
												                <th>Email_verified</th>
												                <td>{{ user.emailVerified }}</td>
												            </tr> #}
				{# <tr>
												                <th>Password</th>
												                <td>{{ user.password }}</td>
												            </tr> #}
				<tr>
					<th>Créer le</th>
					<td>{{ user.createdAt ? user.createdAt|date('Y-m-d H:i:s') : '' }}</td>
				</tr>
				<tr>
					<th>Dernière Connexion</th>
					<td>{{ user.lastLoginAt ? user.lastLoginAt|date('Y-m-d H:i:s') : '' }}</td>
				</tr>
				<tr>
					<th>Statut</th>
					<td>
						<span class="badge-{{user.accountStatus|lower}}">
							{{ user.accountStatus }}
						</span>
					</td>
				</tr>
				{# <tr>
												                <th>Role</th>
												                <td>{{ user.role }}</td>
												            </tr> #}
				<tr>
					<th>Photo de profil</th>
					<td>{{ user.profilePicture }}</td>
				</tr>
			</tbody>
		</table>

		

		<a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn-outline">Modifier le profil</a>


		{# <a href="{{ path('app_user_index') }}">back to list</a> #}

		{# <a href="{{ path('app_user_edit', {'id': user.id}) }}">edit</a> #}

		{{ include('user/_delete_form.html.twig') }}
	{% endblock %}
