<form method="post" action="{{ path('app_user_delete',{'id': user.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer définitivement l\'utilisateur {{ user.firstName }} {{ user.lastName }} ? cette action est irréversible.');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete'~ user.id) }}">
    <button class="btn-primary" type="submit" aria-label="Supprimer l'utilisateur {{ user.firstName }} {{ user.lastName }}">
		{# <img class="dashboard__icon" src="{{asset('icons/compte/trash_white.svg')}}" alt="" aria-hidden="true"> #}
		Supprimer l'utilisateur
	</button>
</form>
