{% extends 'base.html.twig' %}

{% block title %}Bonjour
	{{app.user.lastname}}!
{% endblock %}

{% block body %}


	<div class="dashboard">
		<div class="dashboard__wrapper">
			<div class="dashboard__title">
				<img class="dashboard__icon" src="{{asset('icons/dashboard/flag_red.svg')}}" alt="" aria-hidden="true">
				<h1>Tableau de bord Admin</h1>
			</div>
			<p class="text-m ">Suivez vos utilisateurs</p>
		</div>
			{% for message in app.flashes('success')%}
				<div class=" alert alert-success alert-dismissible fade show">
					{{message}}
					<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"</button>
				{% endfor %}
			</div>


		<div class="stats__grid">
			<h2 class="stats__grid-title">Statistiques générales</h2>
			<div class="stats__wrap">
				<div class="stats__card">
					<p class="stats__title">Nombres d'utilisateurs</p>
					<img class="stats__icon" src="{{asset('icons/dashboard/calendar_white.svg')}}" alt="" aria-hidden="true">
					<p class="stats__number">0</p>
					<p class="stats__p">Total</p>
				</div>

				<div class="stats__card">
					<p class="stats__title">Nouveaux inscrits</p>
					<img class="stats__icon trophy" src="{{asset('icons/dashboard/trophy_white.svg')}}" alt="" aria-hidden="true">
					<p class="stats__number">0</p>
					<p class="stats__p">ce mois</p>
				</div>
				<div class="stats__card">
					<p class="stats__title">Moto enregistrées</p>
					<img class="stats__icon flag" src="{{asset('icons/dashboard/lap_white.svg')}}" alt="" aria-hidden="true">
					<p class="stats__number">0</p>
					<p class="stats__p">Total</p>
				</div>


				<div class="stats__card">
					<p class="stats__title">Maintenances enregistrées</p>
					<img class="stats__icon time " src="{{asset('icons/dashboard/time_white.svg')}}" alt="" aria-hidden="true">
					<p class="stats__number">0</p>
					<p class="stats__p">Total</p>
				</div>
			</div>
		</div>

		<div class="section-card__grid">
			<h2 class="section-card__grid-title">Gestion des utilisateurs</h2>
			<div class="section-card">
				<div class="section-card__header">
					<img src="{{asset('icons/dashboard/calendar_red.svg')}}" alt="" aria-hidden="true">
					<p class="section-card__title">liste des derniers inscrits</p>
				</div>
				<div class="section-card__empty">
					<img class="section-card__empty-icon" src="{{asset('icons/dashboard/calendar_grey.svg')}}" alt="" aria-hidden="true">
					<p class="section-card__empty-text">Aucun utilisateurs</p>
				</div>
			</div>
			<div class="section-card">
				<div class="section-card__header">
					<img src="{{asset('icons/dashboard/calendar_red.svg')}}" alt="calendar">
					<p class="section-card__title">Utilisateurs actifs/inactifs</p>
				</div>
				<div class="section-card__empty">
					<img class="section-card__empty-icon" src="{{asset('icons/dashboard/calendar_grey.svg')}}" alt="calendar">
					<p class="section-card__empty-text">Aucun utilisateurs</p>
				</div>
			</div>
			<div class="section-card">
				<div class="section-card__header">
					<img src="{{asset('icons/dashboard/calendar_red.svg')}}" alt="calendar">
					<p class="section-card__title">Changement de role d'un utilisateurs</p>
				</div>
				<div class="section-card__empty">
					<img class="section-card__empty-icon" src="{{asset('icons/dashboard/calendar_grey.svg')}}" alt="calendar">
					<p class="section-card__empty-text">aucun role changé</p>
				</div>
			</div>


		</div>
	</div>


{% endblock %}
