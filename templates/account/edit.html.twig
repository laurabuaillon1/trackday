{% extends 'base.html.twig' %}

{% block title %}Modifier mon compte{% endblock %}

{% block body %}
    <h1>Modifier mon compte</h1>

    {# On écrit la balise form à la main #}
    <form method="post" action="{{ path('app_account_edit') }}" enctype="multipart/form-data">
        
        <div class="form-field">
            <label for="lastname">Nom :</label>
            <input type="text" id="lastname" name="lastname" value="{{ app.user.lastName }}">
        </div>

        <div class="form-field">
            <label for="firstname">Prénom :</label>
            <input type="text" id="firstname" name="firstname" value="{{ app.user.firstName }}">
        </div>

        <div class="form-field">
            <label for="user_profile_picture">Photo de profil :</label>
            <input type="file" id="user_profile_picture" name="profile_picture">
        </div>

        <button type="submit" class="btn-primary">Enregistrer les modifications</button>
    </form>
{% endblock %}