{% extends 'base.html.twig' %}

{% block title %}Mon compte
{% endblock %}

{% block body %}
	{# HEADER #}
	<header class="dashboard">
		<div class="dashboard__wrapper">
			<div class="dashboard__title">
				<img class="dashboard__icon" src="{{asset('icons/compte/user.svg')}}" alt="" aria-hidden="true">
				<h1>Mon compte</h1>
			</div>
			<p class="text-xs">Gérez vos paramètres et préférences</p>
		</div>
	</header>

	<div
		class="accordion__wrap">
		{# ACCORDION 1 - INFORMATION #}
		<section class="accordion" id="accordionOne">
			<div class="accordion-item">
				<h2 class="accordion-header">
					<button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne" aria-label="Développer les informations du compte">
						<img class="accordion__icon-round" src="{{asset('icons/compte/user_profil.svg')}}" alt="" aria-hidden="true">
						Information du compte
					</button>
				</h2>

				{# Accordion body  #}
				<div id="collapseOne" class="accordion__collapse collapse show" data-bs-parent="#accordionExample">
					<form class="accordion__form" action="{{path('app_account_edit')}}" method="post" enctype="multipart/form-data">
						<input
						type="hidden" name="_token" value="{{ csrf_token('update_profile') }}">

						{# Photo dans le form #}
						<div class="accordion__field">
							<label class="accordion__label text-s">Photo de profil:</label>
							<input class="accordion__form-photo" type="file" id="user_profile_picture" name="profile_picture">
							<span class="accordion__photo-hint text-xs text-grey">JPG, PNG ou GIF (max. 5MB)</span>
						</div>

						<div class="accordion__field">
							<label class="accordion__label" for="lastname">Nom:</label>
							<input class="accordion__input" type="file" id="lastname" name="lastname" value="{{ app.user.lastName }}"/>
						</div>

						<div class="accordion__field">
							<label class="accordion__label" for="firstname">Prénom:</label>
							<input class="accordion__input" type="text" id="firstname" name="firstname" value="{{ app.user.firstName }}"/>
						</div>

						<div class="accordion__field">
							<label class="accordion__label" for="email">Email:</label>
							<input class="accordion__input accordion__input--disabled" type="email" id="email" name="email" value="{{ app.user.email }}" aria-disabled="true"/>
							<span class="accordion__hint text-xs text-grey">L'email ne peut pas être modifié</span>
						</div>

						<button type="submit" class="btn-primary" aria-label="Enregistrer les modifications de mon profil">Enregistrer les modifications</button>
					</form>
				</div>
			</div>
		</section>

		{# ACCORDION 2 - HELP #}

		<section class="accordion" id="accordionThree">
			<div class="accordion-item">
				<h2 class="accordion-header">
					<button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo" aria-label="Aide et support">
						<img class="accordion__icon-round" src="{{asset('icons/compte/help.svg')}}" alt="" aria-hidden="true">
						Aide et Support
					</button>
				</h2>

				{# Accordion body  #}
				<div id="collapseTwo" class="accordion__collapse collapse show" data-bs-parent="#accordionExample">
					<a href="#" class="accordion__link ">
						<img class="sidebar__icon" src="{{ asset('icons/sidebar/settings_gray.svg') }}" width="20" height="20" alt="" aria-hidden="true">
						<span>Contactez-nous</span>
					</a>
				</div>
			</div>
		</section>

		{# ACCORDION 3 - LEGAL INFORMATION #}
		<section class="accordion" id="accordionThree">
			<div class="accordion-item">
				<h2 class="accordion-header">
					<button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="true" aria-controls="collapseThree" aria-label="Développer les informations légal">
						<img class="accordion__icon-round" src="{{asset('icons/compte/help.svg')}}" alt="" aria-hidden="true">
						Information légales
					</button>
				</h2>
				{# Accordion body  #}
				<div id="collapseThree" class="accordion__collapse collapse show" data-bs-parent="#accordionExample" aria-label="Liens légaux">
					<a href="#" class="accordion__link ">Conditions d'utilisation</a>
					<a href="#" class="accordion__link ">Politique de confidentialité</a>
					<a href="#" class="accordion__link ">Mentions légales</a>
				</div>
			</div>
		</section>


		{# DELETE COUNT CONTAINER #}
		<section class="card">
			<div class="card__header">
				<img class="card__icon" src="{{asset('icons/compte/infos.svg')}}" alt="" aria-hidden="true">
				<h2 class="text-m">Zone dangereuse</h2>
			</div>

			<div class="card__body">
				<div class="card__column">
					<div class="card__info">
						<h3 class="text-s">Déconnexion</h3>
						<p class="text-xs">Se déconnecter de l'application</p>
					</div>
					<form class="card__form" method="post" action="{{ path('app_logout') }}">
						<input type="hidden" name="_token" value="{{ csrf_token('logout') }}">
						<button type="submit" class=" card__button btn-secondary">
							<img class="dashboard__icon" src="{{asset('icons/compte/logout_black.svg')}}" alt="" aria-hidden="true">
							Se déconnecter
						</button>
					</form>
				</div>
				<hr>

				<div class="card__column">
					<div class="card__info">
						<h3 class="card__title-delete text-s">Supprimer mon compte</h3>
						<p class="card__text-delete text-xs">Attention,cette action est irréversible</p>
					</div>
					{{include ('account/_delete_form.html.twig') }}
				</div>
			</div>
		</section>
	</div>
{% endblock %}
