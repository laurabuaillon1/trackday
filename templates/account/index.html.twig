{% extends 'base.html.twig' %}

{% block title %}Mon compte
{% endblock %}

{% block body %}
	<div class="dashboard">
		<div class="dashboard__wrapper">
			<div class="dashboard__title">
				<img class="dashboard__icon" src="{{asset('icons/compte/user.svg')}}" alt="" aria-hidden="true">
				<h1>Mon compte</h1>
			</div>
			<p class="text-xs">Gérez vos paramètres et préférences</p>
		</div>
	</div>

	<div>
		{# Accordion header  #}
		<div class="accordion" id="accordionExample">
			<div class="accordion-item">
				<h2 class="accordion-header">
					<button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
						<img class="accordion__icon-round" src="{{asset('icons/compte/user_profil.svg')}}" alt="" aria-hidden="true">
						Information du compte
					</button>
				</h2>

				{# Accordion body  #}
				<div id="collapseOne" class="accordion__collapse collapse show" data-bs-parent="#accordionExample">
					<div class="accordion__body">
						<div class="accordion__photo">
							<label class="accordion__label text-s">Photo de profil:</label>
							<div class="accordion__photo-row">
								<div class="accordion__avatar">
									<svg width="28" height="28" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
										<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
										<circle cx="12" cy="7" r="4"/>
									</svg>
								</div>
								<div class="accordion__photo-actions">
									<input type="file" id="user_profile_picture" name="user[profile_picture]" placeholder="Cliquer pour ajouter une photo">
									</input>
								<span class="accordion__photo-hint text-xs text-grey">JPG, PNG ou GIF (max. 5MB)</span>
							</div>
						</div>
					</div>

					<form action="{{path('app_account_edit')}}" method="post" enctype="multipart/form-data">
						<input type="hidden" name="_token" value="{{ csrf_token('update_profile') }}">

						{# Photo dans le form #}
						<input type="file" id="user_profile_picture" name="profile_picture">
						
						<div class="accordion__field">
							<label class="accordion__label" for="lastname">Nom:</label>
							<input class="accordion__input" type="text" id="fullname" name="lastname" value="{{ app.user.lastName }}"/>
						</div>

						<div class="accordion__field">
							<label class="accordion__label" for="firstname">Prénom:</label>
							<input class="accordion__input" type="text" id="fullname" name="firstname" value="{{ app.user.firstName }}"/>
						</div>

						<div class="accordion__field">
							<label class="accordion__label" for="email">Email:</label>
							<input class="accordion__input accordion__input--disabled" type="email" id="email" name="email" value="{{ app.user.email }}" disabled/>
							<span class="accordion__hint text-xs text-grey">L'email ne peut pas être modifié</span>
						</div>

						<button type="submit" class="btn-primary">Enregistrer les modifications</button>
					</form>
				</div>
			</div>
		</div>
	</div>
	<div class="accordion-item">
		<h2 class="accordion-header">
			<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
				Accordion Item #2
			</button>
		</h2>
		<div id="collapseTwo" class="accordion-collapse collapse" data-bs-parent="#accordionExample">
			<div class="accordion-body">
				<strong>This is the second item’s accordion body.</strong>
				It is hidden by default, until the collapse plugin adds the appropriate classes that we use to style each element. These classes control the overall appearance, as well as the showing and hiding via CSS transitions. You can modify any of this with custom CSS or overriding our default variables. It’s also worth noting that just about any HTML can go within the
				<code>.accordion-body</code>, though the transition does limit overflow.
			</div>
		</div>
	</div>
	<div class="accordion-item">
		<h2 class="accordion-header">
			<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
				Accordion Item #3
			</button>
		</h2>
		<div id="collapseThree" class="accordion-collapse collapse" data-bs-parent="#accordionExample">
			<div class="accordion-body">
				<strong>This is the third item’s accordion body.</strong>
				It is hidden by default, until the collapse plugin adds the appropriate classes that we use to style each element. These classes control the overall appearance, as well as the showing and hiding via CSS transitions. You can modify any of this with custom CSS or overriding our default variables. It’s also worth noting that just about any HTML can go within the
				<code>.accordion-body</code>, though the transition does limit overflow.
			</div>
		</div>
	</div>
</div>{# DELETE COUNT CONTAINER #}<div class="card">
	<div class="card__header">
		<img class="card__icon" src="{{asset('icons/compte/infos.svg')}}" alt="" aria-hidden="true">
		<h2 class="text-m">Zone dangereuse</h2>
	</div>

	<div class="card__body">
		<div class="card__column">
			<div class="card__info">
				<h3 class="text-s">Déconnexion</h3>
				<p class="text-xs">Se déconnecter de l'application</p>
			</div>
			<form class="card__form" method="post" action="{{ path('app_logout') }}">
				<input type="hidden" name="_token" value="{{ csrf_token('logout') }}">
				<button type="submit" class=" card__button btn-secondary">
					<img class="dashboard__icon" src="{{asset('icons/compte/logout_black.svg')}}" alt="" aria-hidden="true">
					Se déconnecter
				</button>
			</form>
		</div>
		<hr>

		<div class="card__column">
			<div class="card__info">
				<h3 class="card__title-delete text-s">Supprimer mon compte</h3>
				<p class="card__text-delete text-xs">Attention,cette action est irréversible</p>
			</div>
			<form class="card__form" method="post" action="{{ path('app_logout') }}">
				<input type="hidden" name="_token" value="{{ csrf_token('logout') }}">
				<button type="submit" class=" card__button btn-primary">
					<img class="dashboard__icon" src="{{asset('icons/compte/trash_white.svg')}}" alt="" aria-hidden="true">
					Supprimer le compte
				</button>
			</form>
		</div>
	</div>
</div>{% endblock %}
