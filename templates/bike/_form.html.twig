		{{ form_widget(form.photo_url) }}
		{{ form_errors(form.photo_url) }}
	</div>
	<div class="form-field">
		{{ form_label(form.nickname) }}
		{{ form_widget(form.nickname) }}
		{{ form_errors(form.nickname) }}
