<form method="post" action="{{ path('app_bike_delete', {'id': bike.id}) }}" onsubmit="return confirm ('Êtes-vous sûr de vouloir supprimer cette moto ?Cette action est irréversible.')">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ bike.id) }}">
    <button class="btn-primary btn-primary--full " type="submit" aria-label="Supprimer définitivement ma moto">Supprimer</button>
</form>
