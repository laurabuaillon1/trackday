{% extends 'base.html.twig' %}

{% block title %}Bike{% endblock %}

{% block body %}
    <h1>Bike</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ bike.id }}</td>
            </tr>
            <tr>
                <th>Nickname</th>
                <td>{{ bike.nickname }}</td>
            </tr>
            <tr>
                <th>Brand</th>
                <td>{{ bike.brand }}</td>
            </tr>
            <tr>
                <th>Model</th>
                <td>{{ bike.model }}</td>
            </tr>
            <tr>
                <th>Year</th>
                <td>{{ bike.year }}</td>
            </tr>
            <tr>
                <th>Displacement</th>
                <td>{{ bike.displacement }}</td>
            </tr>
            <tr>
                <th>Color</th>
                <td>{{ bike.color }}</td>
            </tr>
            <tr>
                <th>License_plate</th>
                <td>{{ bike.licensePlate }}</td>
            </tr>
            <tr>
                <th>Purchase_date</th>
                <td>{{ bike.purchaseDate ? bike.purchaseDate|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Mileage</th>
                <td>{{ bike.mileage }}</td>
            </tr>
            <tr>
                <th>Hours</th>
                <td>{{ bike.hours }}</td>
            </tr>
            <tr>
                <th>Usage_unit</th>
                <td>{{ bike.usageUnit }}</td>
            </tr>
            <tr>
                <th>Last_service_date</th>
                <td>{{ bike.lastServiceDate ? bike.lastServiceDate|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Next_service_km</th>
                <td>{{ bike.nextServiceKm }}</td>
            </tr>
            <tr>
                <th>Next_service_hours</th>
                <td>{{ bike.nextServiceHours }}</td>
            </tr>
            <tr>
                <th>Photo_url</th>
                <td>{{ bike.photoUrl }}</td>
            </tr>
            <tr>
                <th>Notes</th>
                <td>{{ bike.notes }}</td>
            </tr>
            <tr>
                <th>Is_active</th>
                <td>{{ bike.isActive ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Created_at</th>
                <td>{{ bike.createdAt ? bike.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Updated_at</th>
                <td>{{ bike.updatedAt ? bike.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_bike_index') }}">back to list</a>

    <a href="{{ path('app_bike_edit', {'id': bike.id}) }}">edit</a>

    {{ include('bike/_delete_form.html.twig') }}
{% endblock %}
