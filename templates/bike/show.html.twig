{% extends 'base.html.twig' %}

{% block title %}
	{{ bike.nickname }}
{% endblock %}

{% block body %}
	<div class="bike-detail">
		<div class="bike-detail__wrap">
			<div class="bike-detail__back">
				<img src="{{asset('icons/authentification/arrow_left.svg')}}" width="16" height="16" alt="" aria-hidden="true">
                <a class="auth-card__link font-medium" href="{{ path('app_bike_index') }}">Retourner au garage</a>
			</div>
			<div class="bike-detail__header">
				<img class="bike-detail__img" src={{ bike.photoUrl }} alt="">

				<div class="bike-detail__info">
					<h1 class="bike-detail__title">{{ bike.nickname }}</h1>
					<div class="bike-detail__specs">
						<p class="text-s">{{ bike.year }}</p>
						<p class="text-s">{{ bike.displacement }}</p>
						<p class="text-s">{{ bike.color }}</p>
					</div>
					<p class="bike-detail__license text-l font-bold">{{ bike.licensePlate }}</p>
				</div>
			</div>
		</div>

		{# //CARD - INFORMATION #}

		<div class="bike-detail__card">
			<h2 class="bike-detail__section-title text-m">Informations</h2>

			<div class="bike-detail__stats">
				<div class="bike-detail__stat">
					<div class="bike-card__label">
						<img class="bike-card__icon" src="{{asset('icons/garage/counter_grey.svg')}}" alt="">
						<p class="text-s text-grey">Kilométrage</p>
					</div>
					<p class="text-s text-blue">{{ bike.mileage }}{{ bike.hours }}</p>

				</div>
				<div class="bike-detail__stat">
					<div class="bike-card__label">
						<img class="bike-card__icon" src="{{asset('icons/garage/calendar_grey.svg')}}" alt="">
						<p class="text-s text-grey">Dernier entretien</p>
					</div>
					<p class="text-s text-blue">{{ bike.lastServiceDate ? bike.lastServiceDate|date('Y-m-d') : '' }}</p>
				</div>
				<div class="bike-detail__stat">
					<div class="bike-card__label">
						<img class="bike-card__icon" src="{{asset('icons/garage/maintenance_grey.svg')}}" alt="">
						<p class="text-s text-grey">Prochain entretien</p>
					</div>
					<p class="text-stext-blue">{{ bike.nextServiceKm }}</p>
					<p>{{ bike.nextServiceHours }}</p>
				</div>
				<div class="bike-detail__stat">
					<div class="bike-card__label">
						<img class="bike-card__icon" src="{{asset('icons/garage/maintenance_grey.svg')}}" alt="">
						<p class="text-s text-grey">Date d'achat</p>
					</div>
					<p class="text-stext-blue">{{ bike.purchaseDate ? bike.purchaseDate|date('Y-m-d') : '' }}</p>

				</div>
				<div class="bike-detail__stat">
					<div class="bike-detail__label">
						<p class="text-s text-grey">Notes</p>
					</div>
					<p class="text-s text-grey">{{ bike.notes }}</p>
				</div>
			</div>
		</div>

		{# //CARD - Historique d'entretien #}
		<div class="bike-detail__card">
			<div class="bike-detail__section-header">
				<h2 class=" text-m">Historique d'entretien</h2>
				<button class="bike-detail__section-action simple-btn" onclick="window.print()">
					<img src="{{asset('icons/garage/print_white.svg')}}" alt="">
					<p class="text-s text-grey">Imprimer</p>
				</button>
			</div>

			<div class="bike-detail__stats">
				<div class="bike-card__stat">
					<div class="bike-card__label">
						<img class="bike-card__icon" src="{{asset('icons/garage/counter_grey.svg')}}" alt="">
						<p class="text-s text-grey">Vidange</p>
					</div>
					<p class="text-s text-blue">{{ bike.mileage }}{{ bike.hours }}</p>

				</div>
			</div>
		</div>

		{# //CARD - Documents #}
		<div class="bike-detail__card">
			<div class="bike-detail__section-header">
				<h2 class="text-m">Documents</h2>
				<button class="bike-detail__section-action simple-btn">
					<img src="{{asset('icons/garage/add_white.svg')}}" alt="">
					<p class="text-s text-grey">Ajouter</p>
				</button>
			</div>
			<div class="bike-detail__documents">
				<div class="bike-detail__document">
					<div class="bike-detail__document-type">
						<img class="bike-detail__icon" src="{{asset('icons/garage/file_white.svg')}}" alt="">
						<p class="text-s text-grey">Autre</p>
					</div>
					<p class="bike-detail__number text-s">1</p>
				</div>
				<div class="bike-detail__container">
					<div class="bike-detail__document">
						<p>Nom du document</p>
						<div class="bike-card__controls">
							<a href="{{ path('app_bike_edit', {'id': bike.id}) }}">
								<img class="bike-card__icon" src="{{ asset('icons/garage/download_grey.svg') }}" alt="" aria-hidden="true">
							</a>
							<a href="{{ path('app_bike_delete', {'id': bike.id}) }}">
								<img class="bike-card__icon" src="{{ asset('icons/garage/trash_grey.svg') }}" alt="" aria-hidden="true">
							</a>
						</div>
					</div>
					<div class="bike-detail__document-infos">
						<img class="bike-card__icon" src="{{ asset('icons/garage/calendar_grey.svg') }}" alt="" aria-hidden="true">
						<p>Date</p>
					</div>
					<div class="bike-detail__document-infos">
						<img class="bike-card__icon" src="{{ asset('icons/garage/euros_grey.svg') }}" alt="" aria-hidden="true">
						<p>Prix</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
