{% extends 'base.html.twig' %}

{% block title %}Modifier
	{{bike.nickname}}
{% endblock %}

{% block meta_description %}Modifiez les informations de {{ bike.nickname }} dans votre garage Trackday.{% endblock %}


{% block body %}

	{# NAV BACK #}
